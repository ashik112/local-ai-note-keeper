# Host port mapped to the app (container still listens on 8000). Pick any free port.
APP_PORT=8743
# Bind address on the Docker host: 0.0.0.0 = LAN + port-forward from your router; 127.0.0.1 = this machine only
APP_HOST_BIND=0.0.0.0

# CORS: allow browser origins at http://<LAN IP>:PUBLIC_APP_PORT (RFC1918). Leave false unless you hit CORS
# errors (e.g. UI dev server vs API on another host/port). Opening the bundled UI at http://YOUR_IP:APP_PORT needs this off.
CORS_LAN_ORIGINS=false
# Deprecated alias for CORS_LAN_ORIGINS; used only when CORS_LAN_ORIGINS is unset.
# EXTERNAL_ACCESS_ENABLED=false

# Optional: comma-separated browser origins for CORS (defaults use localhost + PUBLIC_APP_PORT from compose)
# CORS_ORIGINS=http://192.168.1.50:8743,http://10.0.0.12:8743
# Optional regex (e.g. custom domain). When CORS_LAN_ORIGINS=true and unset, RFC1918 LAN origins on PUBLIC_APP_PORT are allowed.
# CORS_ORIGIN_REGEX=
# If you expose the UI on http://PUBLIC_IP or http://LAN_IP, the browser will not give mic access — use HTTPS (see README).
PUBLIC_BASE_URL=
HMAC_SECRET=
HMAC_HEADER_NAME=X-NoteKeeper-Signature
HMAC_TIMESTAMP_HEADER_NAME=X-NoteKeeper-Timestamp
HMAC_MAX_CLOCK_SKEW_SECONDS=300

CHAT_MODEL=gemma2:2b
EMBEDDING_MODEL=nomic-embed-text
WHISPER_MODEL=small.en
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=1

AI_WORKER_CONCURRENCY=1
MAX_AUDIO_SECONDS=600
MAX_UPLOAD_MB=100
QDRANT_COLLECTION=notes
